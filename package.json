{
  "name": "swift-tui-examples-workspace",
  "private": true,
  "version": "0.1.6",
  "license": "MIT",
  "workspaces": [
    "WebExample"
  ],
  "overrides": {
    "@swifttui/web": "https://github.com/SwiftTUI/swift-tui-web/releases/download/0.1.6/swifttui-web-0.1.6.tgz"
  },
  "scripts": {
    "check": "Scripts/check_examples.sh --skip-clean",
    "check:linux": "Scripts/check_examples_linux.sh --skip-clean",
    "check:macos": "Scripts/check_examples_macos.sh --skip-clean",
    "check:web": "Scripts/check_examples_web.sh --skip-clean",
    "check:focused": "Scripts/check_examples_focused_tests.sh",
    "build:webexample": "bun run --cwd WebExample build"
  }
}
